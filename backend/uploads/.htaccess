# Never execute code from the uploads directory — serve/deny only.
php_flag engine off
RemoveHandler .php .phtml .php3 .php4 .php5 .php7 .phps
RemoveType .php .phtml .php3 .php4 .php5 .php7 .phps
<IfModule mod_authz_core.c>
    # Files are streamed through dental_records.php (auth-checked), so deny
    # direct web access to the raw stored files.
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
